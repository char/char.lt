<!DOCTYPE html>
<html lang="{{ lang || "en" }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{{ title }}</title>
    {{ if description }}
      <meta property="og:description" content="{{ description }}" />
    {{ /if }}
    <link rel="preconnect" href="https://rsms.me/">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    {{ await stylesheet("/css/ioskeley.css") }}
    {{ await stylesheet("/css/styles.css") }}
    {{ for href of content.stylesheets || [] }}
      {{ await stylesheet(href) }}
    {{ /for }}
    {{ content.head }}
  </head>
  <body>
    <main>
      {{ include "./navbar.vto" }}
      {{ content.body }}
      {{ include "./footer.vto" }}
    </main>
  </body>
</html>
